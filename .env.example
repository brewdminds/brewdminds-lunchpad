# Resend (https://resend.com) — used by src/app/contact/actions.ts to send
# contact-form notifications. Copy this file to .env.local and fill in real
# values; .env.local is gitignored.

# Required. From an API key created in the Resend dashboard.
RESEND_API_KEY=

# Optional — defaults shown below.
# Recipient of contact-form notifications.
CONTACT_EMAIL_TO=hello@brewdminds.com
# Sender address. Must be on a domain verified in Resend, or leave unset to
# use Resend's shared testing sender (onboarding@resend.dev), which can only
# deliver to the email address on the Resend account itself.
CONTACT_EMAIL_FROM="Brewdminds <onboarding@resend.dev>"
